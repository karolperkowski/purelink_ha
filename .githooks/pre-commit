#!/usr/bin/env bash
# Pre-commit hook: regenerate INDEX.md until it stabilizes, then lint.
# Wired up by: git config core.hooksPath .githooks

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

MAX_ITER=5
prev_hash=""
i=0
while [ $i -lt $MAX_ITER ]; do
    i=$((i + 1))
    python tools/update_index.py
    new_hash=$(git hash-object INDEX.md)
    if [ "$new_hash" = "$prev_hash" ]; then
        break
    fi
    git add INDEX.md
    prev_hash="$new_hash"
done

if [ $i -eq $MAX_ITER ]; then
    echo "WARN: INDEX.md did not converge in $MAX_ITER iterations" >&2
fi

./lint.sh
